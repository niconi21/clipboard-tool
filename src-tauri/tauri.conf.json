{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "clipboard-tool",
  "version": "1.2.1",
  "identifier": "com.clipboard-tool.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Clipboard Tool",
        "width": 720,
        "height": 520,
        "resizable": true,
        "minWidth": 400,
        "minHeight": 300,
        "center": true,
        "visible": false,
        "decorations": false,
        "transparent": true,
        "shadow": true,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; connect-src 'self' ipc: http://ipc.localhost; font-src 'self' data:; frame-src 'none'; object-src 'none';"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "niconi21",
    "copyright": "Copyright © 2026 niconi21. MIT License.",
    "shortDescription": "Cross-platform clipboard manager",
    "longDescription": "A local-first clipboard history manager. Capture, search, and organize everything you copy — text, URLs, code, colors and more.",
    "linux": {
      "deb": {
        "depends": []
      }
    }
  }
}
