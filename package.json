{
  "name": "clipboard-tool",
  "private": true,
  "version": "1.3.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "XDG_DATA_HOME=/tmp/clipboard-test tauri dev",
    "tauri:build": "tauri build",
    "cargo:clean": "cargo clean --manifest-path src-tauri/Cargo.toml",
    "cargo:check": "cargo check --manifest-path src-tauri/Cargo.toml",
    "clean": "npm run cargo:clean && rm -rf dist",
    "clean:dev": "rm -rf /tmp/clipboard-test",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-autostart": "^2.5.1",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "@tauri-apps/plugin-global-shortcut": "^2.3.1",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-sql": "^2.3.2",
    "@types/dompurify": "^3.2.0",
    "dompurify": "^3.3.3",
    "highlight.js": "^11.11.1",
    "i18next": "^25.8.17",
    "marked": "^17.0.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-i18next": "^16.5.6"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.0",
    "@testing-library/react": "^16.0",
    "@testing-library/user-event": "^14.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "@vitest/coverage-v8": "^2.0",
    "framer-motion": "^12.37.0",
    "jsdom": "^29.0.0",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.8.3",
    "vite": "^8.0.2",
    "vitest": "^2.0"
  }
}
